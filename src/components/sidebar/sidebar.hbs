<aside class="sidebar">
	<div class="sidebarHeader">
		<h1 class="appTitle">Noterian</h1>
	</div>

	<div class="actionMenu">
		<div class="searchBox disabled">
		    <img src="/icons/search.svg" class="icon searchIcon" />
			<input
				type="text"
				class="searchInput"
				placeholder="Поиск"
				value="{{searchQuery}}"
			/>
		</div>
		<button class="sidebarButton disabled">
			<img src="/icons/home.svg" class="icon" />
			Главная
		</button>
		<button class="sidebarButton disabled">
			<img src="/icons/bookmark.svg" class="icon" />
			Библиотека
		</button>
		<button class="sidebarButton disabled">
			<img src="/icons/settings.svg" class="icon" />
			Настройки
		</button>
		<button id="logoutBtn" class="logoutButton sidebarButton">
			<img src="/icons/logout.svg" class="icon" />
			Выйти
		</button>
	</div>

	<hr class="barrier" />

	<div class="notesList">
		{{#each notes}}
		<div
			class="noteItem {{#if (eq this.id ../activeNoteId)}}active{{/if}}"
			data-note-id="{{this.id}}"
		>
			<img src="/icons/{{this.icon}}.svg" class="icon" />
			<div class="noteItemTitle">{{this.title}}</div>
		</div>
		{{else}}
		<div class="emptyNotes">
			<p>У вас пока нет заметок</p>
		</div>
		{{/each}}
	</div>
</aside>
