<aside class="sidebar">
	<div class="sidebarHeader">
		<h1 class="appTitle">Noterian</h1>
	</div>

	<div class="actionMenu">
		<div class="searchBox">
			<input
				type="text"
				class="searchInput"
				placeholder="Поиск"
				value="{{searchQuery}}"
			/>
		</div>
		<button class="sidebarButton">
			<span class="actionIcon">➕</span>
			Главная
		</button>
		<button class="sidebarButton">
			<span class="actionIcon">🗑️</span>
			Библиотека
		</button>
		<button class="sidebarButton">
			<span class="actionIcon">⚙️</span>
			Настройки
		</button>
		<button id="logoutBtn" class="logoutButton sidebarButton">
		    <span class="actionIcon">👋</span>
            Выйти
        </button>
	</div>

	<hr class="barrier" />

	<div class="notesList">
		{{#each notes}}
		<div
			class="noteItem {{#if (eq this.id ../activeNoteId)}}active{{/if}}"
			data-note-id="{{this.id}}"
		>
			<span class="actionIcon">➕</span>
			<div class="noteItemTitle">{{this.title}}</div>
		</div>
		{{else}}
		<div class="emptyNotes">
			<p>У вас пока нет заметок</p>
		</div>
		{{/each}}
	</div>
</aside>
