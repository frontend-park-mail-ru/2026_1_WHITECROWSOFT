<aside class="sidebar">
	<div class="sidebar__header">
		<h1 class="logo__title">Noterian</h1>
	</div>

	<div class="sidebar__actionMenu">
		<div class="search disabled">
		    <img src="/icons/search.svg" class="icon search__icon" />
			<input
				type="text"
				class="input search__input"
				placeholder="Поиск"
				value="{{searchQuery}}"
			/>
		</div>
		<button class="sidebar__btn disabled">
			<img src="/icons/home.svg" class="icon" />
			Главная
		</button>
		<button class="sidebar__btn disabled">
			<img src="/icons/bookmark.svg" class="icon" />
			Библиотека
		</button>
		<button class="sidebar__btn disabled">
			<img src="/icons/settings.svg" class="icon" />
			Настройки
		</button>
		<button id="logoutBtn" class="logoutButton sidebar__btn">
			<img src="/icons/logout.svg" class="icon" />
			Выйти
		</button>
	</div>

	<hr class="sidebar__barrier" />

	<div class="sidebar__notesList">
		{{#each notes}}
		<div
			class="sidebar__noteItem {{#if (eq this.id ../activeNoteId)}}active{{/if}}"
			data-note-id="{{this.id}}"
		>
			<img src="/icons/{{this.icon}}.svg" class="icon" />
			<div class="sidebar__noteItemTitle">{{this.title}}</div>
		</div>
		{{else}}
		<div class="emptyNotes">
			<p>У вас пока нет заметок</p>
		</div>
		{{/each}}
	</div>
</aside>
