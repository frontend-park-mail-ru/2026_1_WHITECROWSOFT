<div class="mainContainer">
    
    <aside class="sidebar">
        <div class="sidebarHeader">
            <h1 class="appTitle">Noterian</h1>
             <button id="logoutBtn" class="logoutButton" style="margin-top:10px;padding:8px 16px;cursor:pointer">
                Выйти
            </button>
        </div>

        <div class="sidebarContent">
            <div class="searchSection">
                <div class="searchBox">
                    <button class="searchButton">🔍</button>
                    <input 
                        type="text" 
                        class="searchInput" 
                        placeholder="Поиск"
                        value="{{searchQuery}}"
                    >
                </div>
                
                <div class="actionMenu">
                    <button class="sidebarButton">
                        <span class="actionIcon">➕</span>
                        Главная
                    </button>
                    <button class="sidebarButton">
                        <span class="actionIcon">🗑️</span>
                        Библиотека
                    </button>
                    <button class="sidebarButton">
                        <span class="actionIcon"></span>
                        Настройки
                    </button>
                </div>
            </div>

            <div class="notesList">
                {{#each notes}}
                    <div class="noteItem {{#if (eq this.id ../activeNoteId)}}active{{/if}}" 
                        data-note-id="{{this.id}}">
                        <span class="actionIcon">➕</span>
                        <div class="noteItemTitle">{{this.title}}</div>
                    </div>
                {{else}}
                    <div class="emptyNotes">
                        <p>У вас пока нет заметок</p>
                    </div>
                {{/each}}
            </div>
        </div>
    </aside>

    <main class="mainContent">
        {{#if activeNote}}
            <div class="notePath">
                <span class="pathItem">Библиотека</span>
                <span class="pathSeparator">/</span>
                <span class="pathItem current">{{activeNote.title}}</span>
            </div>

            <div class="noteHeader">
                <input 
                    type="text" 
                    class="noteTitleInput" 
                    value="{{activeNote.title}}"
                    placeholder="Введите название заметки"
                >
            </div>

            <article class="noteContent">
                <h1 class="noteTitle">{{activeNote.title}}</h1>
                <div class="noteBody">
                    {{activeNote.text}}
                </div>
            </article>
        {{else}}
            <div class="emptyState">
                <p>Выберите заметку из списка</p>
            </div>
        {{/if}}
    </main>
</div>