<div class="signupPage">
    <header class="pageHeader">
        {{> components/layout/logo }}
    </header>

    <main class="formContainer">
        <h1 class="formTitle">Регистрация</h1>

        <form id="signupForm" class="authForm" novalidate>
            <div class="formError" data-error-container style="visibility: hidden;">
                <span class="errorMessage" role="alert" data-error-text></span>
            </div>

            <div class="formFields">
                {{> components/forms/input
                    name="username"
                    label="Имя пользователя"
                    type="text"
                    value=formData.username
                    placeholder="river_wyles"
                }}
                <span class="fieldError" data-field-error="username" style="visibility: hidden;" role="alert"></span>

                {{> components/forms/input
                    name="password"
                    label="Пароль"
                    type="password"
                    value=formData.password
                    placeholder="********"
                    autocomplete="off"
                }}
                <span class="fieldError" data-field-error="password" style="visibility: hidden;" role="alert"></span>

                {{> components/forms/input
                    name="passwordConfirm"
                    label="Подтвердить пароль"
                    type="password"
                    value=formData.passwordConfirm
                    placeholder="********"
                    autocomplete="off"
                }}
                <span class="fieldError" data-field-error="passwordConfirm" style="visibility: hidden;" role="alert"></span>
            </div>

            <div class="formButtons">
                {{> components/forms/button
                    type="submit"
                    text="Создать аккаунт"
                    variant="primary"
                    className="submitButton"
                }}
                <span id="authLink"> Есть аккаунт? <a href="/signin"> Войти</a></span>
            </div>
        </form>

    </main>
</div>
